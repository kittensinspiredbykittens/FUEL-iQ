<!DOCTYPE html>
<html>
<head><title>FuelIQ - Register</title></head>
<body style="font-family: sans-serif; max-width: 400px; margin: 50px auto; padding: 20px; border: 1px solid #ccc;">
    <h2>Create Family Account</h2>
    <form method="POST">
        <p><label>Email Account:</label><br><input type="email" name="email" required style="width:100%"></p>
        <p><label>Password:</label><br><input type="password" name="password" required style="width:100%"></p>
        <p><label>Family Last Name:</label><br><input type="text" name="family_name" style="width:100%"></p>
        <button type="submit" style="width:100%; padding:10px; background:#007bff; color:white; border:none;">Register</button>
    </form>
</body>
</html>
